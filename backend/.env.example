# ─────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────
APP_NAME=TalentMatch AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# CORS - comma separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/talentmatch
# Neon (production):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/talentmatch?sslmode=require

# ─────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────
# IMPORTANT: Change this to a strong random string in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ─────────────────────────────────────────
# AI / ML
# ─────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
USE_OPENAI_EMBEDDINGS=false
# OPENAI_API_KEY=sk-...  # Required only if USE_OPENAI_EMBEDDINGS=true

# ─────────────────────────────────────────
# AWS S3 (Optional - for production file storage)
# ─────────────────────────────────────────
USE_S3_STORAGE=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=talentmatch-resumes
# AWS_REGION=us-east-1
